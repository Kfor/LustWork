{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lust Work",
  "version": "0.1.0",
  "identifier": "com.lustwork.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:14567",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Lust Work",
        "width": 480,
        "height": 860,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
