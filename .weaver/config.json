  "implementationLogLabel": "claude",
  "workbenchCommand": "claude -p --verbose --output-format stream-json --dangerously-skip-permissions \"$WEAVER_PROMPT\"",
  "workbenchOutput": "stream-json",
  "workbenchLogLabel": "claude",
  "runnerTemplate": "runner.md",
  "mergeTemplate": "merge.md",
  "workbenchTemplate": "workbench.md",
  "triggerCommand": "claude -p --verbose --output-format stream-json --dangerously-skip-permissions \"$WEAVER_PROMPT\"",
  "triggers": []
}