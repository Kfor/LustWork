  "tasksPath": ".weaver/tasks.yaml",
  "logsPath": ".weaver/logs",
  "worktreesPath": ".weaver/worktrees",
  "templatesPath": ".weaver/templates",
  "defaultBaseBranch": "main",
  "concurrency": 5,
  "taskTimeoutMinutes": 120,
  "branchPrefix": "weaver/",
  "remoteName": "origin",
